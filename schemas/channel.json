{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/channel.json",
  "title": "Channel",
  "description": "A YouTube channel tracked by the station",
  "type": "object",
  "required": ["id", "title", "source", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "YouTube channel ID (e.g. UCxxxxxxxxxxxxxxxxxxxx)"
    },
    "title": {
      "type": "string",
      "description": "Display name of the channel"
    },
    "description": {
      "type": "string",
      "description": "Channel description from YouTube"
    },
    "customUrl": {
      "type": "string",
      "description": "Custom URL handle (e.g. @channelname)"
    },
    "thumbnailUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to the channel thumbnail"
    },
    "subscriberCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Approximate subscriber count"
    },
    "videoCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of public videos"
    },
    "source": {
      "type": "string",
      "const": "youtube",
      "description": "Data provenance — always 'youtube' for channels"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Editorial tags added by the curator"
    }
  },
  "additionalProperties": false
}
