{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/transcript.json",
  "title": "Transcript",
  "description": "A downloaded transcript for a YouTube video",
  "type": "object",
  "required": ["videoId", "language", "segments", "source", "updatedAt"],
  "properties": {
    "videoId": {
      "type": "string",
      "description": "YouTube video ID"
    },
    "language": {
      "type": "string",
      "description": "BCP-47 language code of the transcript"
    },
    "trackKind": {
      "type": "string",
      "description": "Caption track kind (standard, ASR, forced)"
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "number",
            "description": "Start time in seconds"
          },
          "duration": {
            "type": "number",
            "description": "Duration in seconds"
          },
          "text": {
            "type": "string",
            "description": "Transcript text for this segment"
          }
        },
        "required": ["start", "text"]
      },
      "description": "Timed transcript segments"
    },
    "fullText": {
      "type": "string",
      "description": "Full transcript text concatenated from all segments"
    },
    "source": {
      "type": "string",
      "const": "youtube",
      "description": "Data provenance"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the transcript was downloaded"
    }
  },
  "additionalProperties": false
}
