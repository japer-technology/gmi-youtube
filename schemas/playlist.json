{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/playlist.json",
  "title": "Playlist",
  "description": "A YouTube playlist tracked by the station",
  "type": "object",
  "required": ["id", "channelId", "title", "source", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "YouTube playlist ID"
    },
    "channelId": {
      "type": "string",
      "description": "YouTube channel ID that owns this playlist"
    },
    "title": {
      "type": "string",
      "description": "Playlist title"
    },
    "description": {
      "type": "string",
      "description": "Playlist description"
    },
    "thumbnailUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to the playlist thumbnail"
    },
    "itemCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of items in the playlist"
    },
    "videoIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of video IDs in the playlist"
    },
    "source": {
      "type": "string",
      "const": "youtube",
      "description": "Data provenance"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Editorial tags added by the curator"
    }
  },
  "additionalProperties": false
}
