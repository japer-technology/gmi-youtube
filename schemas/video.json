{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/video.json",
  "title": "Video",
  "description": "A YouTube video tracked by the station",
  "type": "object",
  "required": ["id", "channelId", "title", "publishedAt", "source", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "YouTube video ID"
    },
    "channelId": {
      "type": "string",
      "description": "YouTube channel ID that owns this video"
    },
    "title": {
      "type": "string",
      "description": "Video title"
    },
    "description": {
      "type": "string",
      "description": "Video description"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the video was published"
    },
    "thumbnailUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to the video thumbnail"
    },
    "duration": {
      "type": "string",
      "description": "ISO 8601 duration (e.g. PT15M33S)"
    },
    "viewCount": {
      "type": "integer",
      "minimum": 0,
      "description": "View count at time of last update"
    },
    "likeCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Like count at time of last update"
    },
    "liveBroadcastContent": {
      "type": "string",
      "enum": ["none", "live", "upcoming"],
      "description": "Live broadcast state"
    },
    "premiereAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of scheduled premiere or live start time"
    },
    "liveStartedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when a live stream actually started"
    },
    "liveEndedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when a live stream ended"
    },
    "captionsAvailable": {
      "type": "boolean",
      "description": "Whether captions are available for this video"
    },
    "captionTracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Caption track ID" },
          "language": { "type": "string", "description": "BCP-47 language code" },
          "name": { "type": "string", "description": "Track display name" },
          "trackKind": { "type": "string", "description": "Track kind (standard, ASR, forced)" }
        },
        "required": ["language"]
      },
      "description": "Available caption tracks with language and kind"
    },
    "transcriptAvailable": {
      "type": "boolean",
      "description": "Whether a transcript has been downloaded and stored for this video"
    },
    "source": {
      "type": "string",
      "const": "youtube",
      "description": "Data provenance"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Editorial tags added by the curator"
    }
  },
  "additionalProperties": false
}
