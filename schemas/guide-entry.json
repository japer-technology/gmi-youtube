{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/guide-entry.json",
  "title": "Guide Entry",
  "description": "A single entry in the station TV guide",
  "type": "object",
  "required": ["videoId", "channelId", "title", "scheduledAt", "updatedAt"],
  "properties": {
    "videoId": {
      "type": "string",
      "description": "YouTube video ID for this guide slot"
    },
    "channelId": {
      "type": "string",
      "description": "YouTube channel ID that owns the video"
    },
    "title": {
      "type": "string",
      "description": "Display title for the guide entry"
    },
    "channelTitle": {
      "type": "string",
      "description": "Display name of the channel"
    },
    "scheduledAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the scheduled guide slot"
    },
    "duration": {
      "type": "string",
      "description": "ISO 8601 duration (e.g. PT15M33S)"
    },
    "liveBroadcastContent": {
      "type": "string",
      "enum": ["none", "live", "upcoming"],
      "description": "Live broadcast state"
    },
    "premiereAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of scheduled premiere or live start time"
    },
    "block": {
      "type": "string",
      "description": "Named editorial block (e.g. 'morning', 'evening', 'deep-dive')"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update"
    }
  },
  "additionalProperties": false
}
