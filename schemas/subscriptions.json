{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gmi-youtube.github.io/schemas/subscriptions.json",
  "title": "Subscriptions",
  "description": "Index of YouTube channels the user is subscribed to, used as the primary input for scheduled ingestion",
  "type": "object",
  "required": ["channels", "totalCount", "updatedAt"],
  "properties": {
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["channelId", "title"],
        "properties": {
          "channelId": {
            "type": "string",
            "description": "YouTube channel ID"
          },
          "title": {
            "type": "string",
            "description": "Channel display name at time of subscription sync"
          },
          "description": {
            "type": "string",
            "description": "Channel description"
          },
          "thumbnailUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to the channel thumbnail"
          },
          "subscribedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the subscription was created"
          }
        },
        "additionalProperties": false
      },
      "description": "List of subscribed channels with metadata"
    },
    "totalCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of subscriptions"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last subscription sync"
    }
  },
  "additionalProperties": false
}
